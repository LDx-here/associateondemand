{
  "version": 2,
  "buildCommand": "pnpm build",
  "outputDirectory": "dist",
  "installCommand": "pnpm install",
  "framework": null,
  "env": {
    "DATABASE_URL": "@database_url",
    "JWT_SECRET": "@jwt_secret",
    "VITE_APP_ID": "@vite_app_id",
    "OAUTH_SERVER_URL": "@oauth_server_url",
    "VITE_OAUTH_PORTAL_URL": "@vite_oauth_portal_url",
    "OWNER_OPEN_ID": "@owner_open_id",
    "OWNER_NAME": "@owner_name",
    "BUILT_IN_FORGE_API_URL": "@built_in_forge_api_url",
    "BUILT_IN_FORGE_API_KEY": "@built_in_forge_api_key",
    "VITE_FRONTEND_FORGE_API_KEY": "@vite_frontend_forge_api_key",
    "VITE_FRONTEND_FORGE_API_URL": "@vite_frontend_forge_api_url",
    "AIRTABLE_BASE_ID": "@airtable_base_id",
    "AIRTABLE_PAT": "@airtable_pat",
    "RMV_WEBHOOK_SECRET": "@rmv_webhook_secret",
    "GMAIL_NOTIFICATION_EMAIL": "@gmail_notification_email"
  },
  "functions": {
    "server/_core/index.ts": {
      "runtime": "nodejs24.x",
      "memory": 1024
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/server/_core/index.ts" },
    { "source": "/(.*)", "destination": "/client/dist/index.html" }
  ]
}

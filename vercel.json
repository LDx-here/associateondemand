{
  "version": 2,
  "regions": ["iad1"],
  "buildCommand": "pnpm build",
  "outputDirectory": "dist",
  "installCommand": "pnpm install",
  "framework": null,

  "functions": {
    "server/_core/index.ts": {
      "runtime": "nodejs@24.x",
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/server/_core/index.ts" },
    { "source": "/(.*)", "destination": "/client/dist/index.html" }
  ],
  "headers": [
    {
      "source": "/manus-storage/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
